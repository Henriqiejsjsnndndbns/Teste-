#include <Arduino.h>
#include <WiFi.h>
#include <WebServer.h>
#include <WiFiUdp.h>

// Configurações do Wi-Fi próprio do ESP32 (Access Point)
const char* ap_ssid = "ESP32_IA_Network";
const char* ap_password = "ia_password_123"; // Mínimo 8 caracteres

WebServer server(80);
WiFiUDP udp;
unsigned int localUdpPort = 12345;
char packetBuffer[255];

// Variáveis globais para armazenar os dados recebidos da IA
String valor_atual = "0";
String proxima_previsao = "0";
String erro_ia = "0";
String peso_memoria = "0";

// Interface Gráfica do Website integrada na memória do chip
const char HTML_PAGINA[] PROGMEM = R"=====(
<!DOCTYPE html>
<html>
<head>
    <meta charset='UTF-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'>
    <title>Painel de Aprendizado IA</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #121214; color: #e1e1e6; margin: 0; padding: 20px; text-align: center; }
