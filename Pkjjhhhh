                document.getElementById('peso').innerText = data.peso;
            });
        }, 300); // Atualiza os dados na tela a cada 300 milissegundos automaticamente
    </script>
</head>
<body>
    <div class='container'>
        <h1>Cérebro IA - ESP32 Control</h1>
        <div class='status'>● ESP32 Processando Aprendizado</div>
        
        <div class='card'>
            <div class='label'>Estado Atual da Tela (Lido pelo Celular)</div>
            <div class='valor' id='atual'>0.0</div>
        </div>
        <div class='card' style='border-left-color: #8257e5;'>
            <div class='label'>🔮 Próximo Passo Previsto (O Futuro)</div>
            <div class='valor' id='previsao'>0.0</div>
        </div>
        <div class='card erro'>
            <div class='label'>⚠️ Desvio de Erro Atual (Auto-Correção)</div>
            <div class='valor' id='erro'>0.0</div>
        </div>
        <div class='card' style='border-left-color: #ffcd1e;'>
            <div class='label'>🧠 Peso de Memória Atualizado (Evolução)</div>
            <div class='valor' id='peso'>0.0</div>
        </div>
    </div>
