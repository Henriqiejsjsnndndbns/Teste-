        h1 { color: #04d361; font-size: 24px; margin-bottom: 20px; }
        .card { background: #29292e; padding: 15px; margin: 10px 0; border-radius: 8px; border-left: 5px solid #04d361; text-align: left; }
        .card.erro { border-left-color: #f75a68; }
        .label { font-size: 14px; color: #a8a8b3; }
        .valor { font-size: 22px; font-weight: bold; margin-top: 5px; color: #fff; }
        .status { display: inline-block; padding: 5px 10px; background: #121214; border-radius: 20px; font-size: 12px; color: #04d361; margin-bottom: 20px; }
    </style>
    <script>
        setInterval(function() {
            fetch('/dados').then(response => response.json()).then(data => {
                document.getElementById('atual').innerText = data.atual;
