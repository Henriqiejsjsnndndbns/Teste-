)=====";

// Servir a página Web Principal
void handleRoot() {
    server.send(200, "text/html", HTML_PAGINA);
}

// Fornecer dados em JSON para a página atualizar sem dar F5
void handleDados() {
    String json = "{\"atual\":\"" + valor_atual + "\",\"previsao\":\"" + proxima_previsao + "\",\"erro\":\"" + erro_ia + "\",\"peso\":\"" + peso_memoria + "\"}";
    server.send(200, "application/json", json);
}

void setup() {
    Serial.begin(115200);
    
    // Configura o ESP32 como emissor de sinal Wi-Fi próprio
    WiFi.softAP(ap_ssid, ap_password);
    Serial.println("Rede Wi-Fi do ESP32 iniciada!");
    Serial.print("IP da rede do ESP32: ");
    Serial.println(WiFi.softAPIP());

    // Configuração das rotas do Servidor Web
    server.on("/", handleRoot);
    server.on("/dados", handleDados);
    server.begin();

    // Inicia escuta UDP para receber prints processados do Linux
    udp.begin(localUdpPort);
}

void loop() {
    server.handleClient();

    // Verifica se chegaram novos pacotes da IA vindos do Notebook
    int packetSize = udp.parsePacket();
    if (packetSize) {
        int len = udp.read(packetBuffer, 255);
        if (len > 0) {
            packetBuffer[len] = 0;
        }
        String dadosRecebidos = String(packetBuffer);
        
        // Separa os dados recebidos pelo caractere '|'
        int idx1 = dadosRecebidos.indexOf('|');
        int idx2 = dadosRecebidos.indexOf('|', idx1 + 1);
        int idx3 = dadosRecebidos.indexOf('|', idx2 + 1);

        if(idx1 != -1 && idx2 != -1 && idx3 != -1) {
            valor_atual = dadosRecebidos.substring(0, idx1);
            proxima_previsao = dadosRecebidos.substring(idx1 + 1, idx2);
            erro_ia = dadosRecebidos.substring(idx2 + 1, idx3);
            peso_memoria = dadosRecebidos.substring(idx3 + 1);
        }
    }
}
