#include <SPI.h>
#include <nRF24L01.h>
#include <RF24.h>
#include <WiFi.h>
#include <ESPAsyncWebServer.h>
#include <ArduinoJson.h>

// Pinos do nRF24
#define CE_PIN 4
#define CSN_PIN 5

// Configurações
const uint8_t BLE_PRIMARY_CHANNELS[] = {37, 38, 39, 12, 15, 16, 19, 20, 23, 24, 27, 28, 31, 32, 35, 36};
const uint8_t PRIMARY_CHANNEL_COUNT = sizeof(BLE_PRIMARY_CHANNELS) / sizeof(BLE_PRIMARY_CHANNELS[0]);
#define MAX_RUNTIME_MS 3600000 
#define FULL_SCAN_INTERVAL 120000
#define WEB_PORT 8080

// Credenciais WiFi (Modo AP)
const char* apSSID = "MOG-Jammer-Control";
const char* apPassword = "12345678";

// Definição única do objeto radio
RF24 radio(CE_PIN, CSN_PIN);
AsyncWebServer server(WEB_PORT);

// Estado do sistema
bool jammingActive = true;
uint32_t startTime;
uint32_t totalPackets = 0;
uint8_t currentChannel = 37;

void jamBLE();
void checkSafety();
void setupWebServer();

void setup() {
  Serial.begin(115200);
  delay(100);
  
  setCpuFrequencyMhz(160);
  btStop();
  
  if (!radio.begin()) {
    Serial.println("ERRO: Radio falhou");
    while (1);
  }
  
  radio.setPALevel(RF24_PA_MAX);
  radio.setDataRate(RF24_2MBPS);
  radio.setAutoAck(false);
  radio.setAddressWidth(3);
  radio.setRetries(0, 0);
  radio.setCRCLength(RF24_CRC_DISABLED);
  radio.setPayloadSize(32);
  radio.disableDynamicPayloads();
  radio.maskIRQ(true, true, true);
  radio.powerUp();
  
  WiFi.softAP(apSSID, apPassword);
  WiFi.softAPConfig(IPAddress(192, 168, 4, 1), IPAddress(192, 168, 4, 1), IPAddress(255, 255, 255, 0));
  
  Serial.print("AP IP: ");
  Serial.println(WiFi.softAPIP());
  
  startTime = millis();
  
  setupWebServer();
  
  Serial.println("Sistema Pronto. Jamming: ON");
}

void setupWebServer() {
  // Página Principal
  server.on("/", HTTP_GET, [](AsyncWebServerRequest *request){
    String html = "<!DOCTYPE html><html><head><meta name='viewport' content='width=device-width, initial-scale=1'>";
    html += "<style>body{font-family:sans-serif;background:#222;color:#fff;text-align:center;padding:20px;}";
    html += ".btn{padding:15px 30px;font-size:18px;border:none;border-radius:5px;cursor:pointer;margin:10px;}";
    html += ".on{background:#28a745;color:white;} .off{background:#dc3545;color:white;}";
    html += ".stats{background:#333;padding:15px;border-radius:10px;margin-top:20px;}";
    html += "</style></head><body>";
    html += "<h1>MOG Jammer Control</h1>";
    html += "<div class='stats'>";
    html += "<p>Status: <span id='status'>...</span></p>";
    html += "<p>Canal Atual: <span id='ch'>...</span></p>";
    html += "<p>Pacotes Enviados: <span id='pkts'>...</span></p>";
    html += "<p>Tempo Ativo: <span id='uptime'>...</span>s</p>";
    html += "</div>";
    html += "<button class='btn' id='toggleBtn' onclick='toggleJam()'>Carregando...</button>";
    
    html += "<script>";
    html += "function updateStatus() { fetch('/status').then(r=>r.json()).then(d=>{";
    html += "document.getElementById('status').innerText = d.active ? 'ATIVO' : 'PARADO';";
    html += "document.getElementById('ch').innerText = d.channel;";
    html += "document.getElementById('pkts').innerText = d.packets;";
    html += "document.getElementById('uptime').innerText = d.uptime;";
    html += "let btn = document.getElementById('toggleBtn');";
    html += "if(d.active) { btn.innerText='DESATIVAR JAMMING'; btn.className='btn off'; }";
    html += "else { btn.innerText='ATIVAR JAMMING'; btn.className='btn on'; }";
    html += "}); }";
    html += "function toggleJam() { fetch('/toggle').then(updateStatus); }";
    html += "setInterval(updateStatus, 1000);";
    html += "updateStatus();";
    html += "</script></body></html>";
    
    request->send(200, "text/html", html);
  });

  // Endpoint JSON de Status
  server.on("/status", HTTP_GET, [](AsyncWebServerRequest *request){
    StaticJsonDocument<200> doc;
    doc["active"] = jammingActive;
    doc["channel"] = currentChannel;
    doc["packets"] = totalPackets;
    doc["uptime"] = (millis() - startTime) / 1000;
    
    String response;
    serializeJson(doc, response);
    request->send(200, "application/json", response);
  });

  // Endpoint para Alternar
  server.on("/toggle", HTTP_GET, [](AsyncWebServerRequest *request){
    jammingActive = !jammingActive;
    if(jammingActive) {
      radio.powerUp();
    } else {
      radio.powerDown();
    }
    request->send(200, "application/json", "{\"result\":\"ok\"}");
  });

  server.begin();
}

void jamBLE() {
  static uint8_t channelIndex = 0;
  static uint32_t lastChannelChange = 0;
  uint32_t currentTime = millis();
  
  if (!jammingActive) return;

  if (currentTime - lastChannelChange > 5) {
    channelIndex = (channelIndex + 1) % PRIMARY_CHANNEL_COUNT;
    currentChannel = BLE_PRIMARY_CHANNELS[channelIndex];
    radio.setChannel(currentChannel);
    lastChannelChange = currentTime;
    
    uint8_t noise[32];
    for (int i = 0; i < 32; i++) noise[i] = random(256);
    
    radio.writeFast(&noise, sizeof(noise));
    radio.flush_tx();
    radio.writeFast(&noise, sizeof(noise));
    
    totalPackets += 2;
  }
}

void checkSafety() {
  if (millis() - startTime > MAX_RUNTIME_MS) {
    Serial.println("SEGURANÇA: Shutdown automático");
    radio.powerDown();
    WiFi.softAPdisconnect(true);
    esp_deep_sleep_start();
  }
}

void loop() {
  jamBLE();
  checkSafety();
}
