void ServidorPainel::inicializar() {
    server.on("/", [this]() { server.send(200, "text/html", INDEX_HTML); });
    server.begin();
    webSocket.begin();
}

void ServidorPainel::processarEventos() {
    server.handleClient();
    webSocket.loop();
}

void ServidorPainel::dispararTelemetria(float atual, float prev, float erro, MotorIA& motor) {
    EstatisticasIA est = motor.getEstatisticas();
    String json = "{\"at\":" + String(atual, 1) + 
                  ",\"pr\":" + String(prev, 1) + 
                  ",\"er\":" + String(erro, 1) + 
                  ",\"cf\":" + String(est.confianca, 1) + 
                  ",\"an\":" + String(est.total_anomalias) + 
                  ",\"ram\":" + String(esp_get_free_heap_size() / 1024) + "}";
    webSocket.broadcastTXT(json);
}
