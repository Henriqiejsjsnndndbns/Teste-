ServidorAssincrono::ServidorAssincrono() : server(80), webSocket(81), clientes_conectados(0) {}

void ServidorAssincrono::inicializar() {
    server.on("/", [this]() {
        server.send_P(200, "text/html", INDEX_HTML);
    });
    server.begin();
    
    webSocket.begin();
    webSocket.onEvent([this](uint8_t num, W_TYPE type, uint8_t * payload, size_t length) {
        this->gerenciarEventoWS(num, type, payload, length);
    });
}

void ServidorAssincrono::gerenciarEventoWS(uint8_t num, W_TYPE type, uint8_t * payload, size_t length) {
    if (type == W_CONNECTED) {
        clientes_conectados++;
    } else if (type == W_DISCONNECTED) {
        if (clientes_conectados > 0) clientes_conectados--;
    }
}

void ServidorAssincrono::atualizar() {
    server.handleClient();
    webSocket.loop();
}

void ServidorAssincrono::transmitirTelemetria(const TelemetriaIA& dados, uint32_t ram_livre, uint32_t uptime) {
    if (clientes_conectados == 0) return;
    
    char json_buffer[256];
    snprintf(json_buffer, sizeof(json_buffer),
             "{\"at\":%.2f,\"pr\":%.2f,\"er\":%.2f,\"cf\":%.2f,\"an\":%u,\"ram\":%u,\"up\":%u}",
             dados.valor_atual, dados.previsao, dados.erro, dados.confianca,
             dados.total_anomalias, ram_livre / 1024, uptime);
             
    webSocket.broadcastTXT((uint8_t*)json_buffer, strlen(json_buffer));
}
