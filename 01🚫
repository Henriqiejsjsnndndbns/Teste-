ServidorAssincrono::ServidorAssincrono() : server(80), webSocket(81), clientes(0) {}

void ServidorAssincrono::inicializar() {
    server.on("/", [this]() { server.send_P(200, "text/html", INDEX_HTML); });
    server.begin();
    webSocket.begin();
    webSocket.onEvent([this](uint8_t num, WStype_t type, uint8_t * payload, size_t length) {
        this->gerenciarWS(num, type, payload, length);
    });
}

void ServidorAssincrono::gerenciarWS(uint8_t num, WStype_t type, uint8_t * payload, size_t length) {
    if (type == WStype_CONNECTED) clientes++;
    else if (type == WStype_DISCONNECTED) { if(clientes > 0) clientes--; }
}

void ServidorAssincrono::atualizar() {
    server.handleClient();
    webSocket.loop();
}

void ServidorAssincrono::dispararStream(const TelemetriaIA& dados, uint32_t heap, uint32_t uptime) {
    if (clientes == 0) return;
    char json_buffer[256]; // Corrigido: Agora sim um array de 256 bytes explícito
    snprintf(json_buffer, sizeof(json_buffer),
             "{\"at\":\"%s\",\"pr\":\"%s\",\"cf\":%.1f,\"pc\":%.1f,\"an\":%u,\"ram\":%u}",
             dados.estado_atual, dados.previsao, dados.confianca, dados.precisao,
             dados.total_anomalias, heap / 1024);
    webSocket.broadcastTXT((uint8_t*)json_buffer, strlen(json_buffer));
}
